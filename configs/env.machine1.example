# Machine 1 / daily driver / control plane
# Copy to .env at repo root, then edit paths as needed.

ORCH_BASE_URL=http://127.0.0.1:8001/v1
DEV_BASE_URL=http://10.10.10.2:8002/v1
REVIEW_BASE_URL=http://10.10.10.2:8003/v1

# These model paths must be valid on the machine hosting each server.
# ORCH_MODEL is on Machine 1; DEV_MODEL/REVIEW_MODEL are on Machine 2.
#
# Use absolute paths. If the Machine 2 short username is also yours, $HOME
# expands correctly; if it differs, set HOME_M2 below and reference it,
# or just write the absolute path of the *Machine 2* home directory.
HOME_M2=${HOME}
ORCH_MODEL=${HOME}/ai/models/orchestrator-qwen36-35b-a3b-heretic-bf16
DEV_MODEL=${HOME_M2}/ai/models/developer-qwen36-27b-heretic2-mixed94
REVIEW_MODEL=${HOME_M2}/ai/models/reviewer-qwen36-27b-heretic-bf16

LOCAL_API_KEY=not-needed

WORKSPACE=$HOME/ai/workspaces/default_project
MAX_REVIEW_LOOPS=3
ALLOW_UNSAFE_TOOLS=0

# Optional experimental MTP / security-review endpoint.
MTP35_BASE_URL=http://10.10.10.2:8004/v1
MTP35_MODEL=mtplx

# Paid remote providers behind the meter (ports 9004/9005). The meter — not this file — holds these;
# set via `launchpad secrets set ZAI_API_KEY` / `DEEPSEEK_API_KEY` and supply them to the meter via
# ~/ai/dashboard/dashboard.env (git-ignored) or 1Password. See docs/observability.md. Never commit
# real keys. The meter skips a remote port whose key is unset.
# ZAI_API_KEY=
# DEEPSEEK_API_KEY=
